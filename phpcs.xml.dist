<?xml version="1.0"?>
<ruleset name="Internal Link Builder">
	<description>Coding standards for Internal Link Builder.</description>

	<file>.</file>

	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/tests/*</exclude-pattern>

	<arg value="sp"/>
	<arg name="basepath" value="."/>
	<arg name="parallel" value="8"/>
	<arg name="extensions" value="php"/>

	<config name="minimum_supported_wp_version" value="5.8"/>
	<config name="testVersion" value="7.4-"/>

	<rule ref="WordPress">
		<!-- The plugin owns two custom tables; direct queries are by design. -->
		<exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
		<exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
		<!--
			The "ilb"/"ILB" prefix predates this ruleset and is baked into stored
			data (option keys, meta keys, table names). Renaming it now would
			break existing installs, so the short-prefix check is disabled as a
			deliberate, documented exception.
		-->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.ShortPrefixPassed"/>
	</rule>

	<rule ref="WordPress.NamingConventions.ValidVariableName">
		<properties>
			<!-- PHP DOM extension property names cannot be renamed. -->
			<property name="allowed_custom_properties" type="array">
				<element value="nodeValue"/>
				<element value="nodeName"/>
				<element value="nodeType"/>
				<element value="parentNode"/>
				<element value="childNodes"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="internal-link-builder"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="ilb"/>
				<element value="ILB"/>
			</property>
		</properties>
	</rule>

	<rule ref="PHPCompatibilityWP"/>
</ruleset>
